# Порт сервера
PORT=3000
HOST=0.0.0.0

# DeepGram API ключ (опционально — нужен для DeepGram STT и TTS)
DEEPGRAM_API_KEY=

# OpenAI API ключ (опционально — нужен для OpenAI перевода)
OPENAI_API_KEY=

# LibreTranslate URL (по умолчанию публичный API)
LIBRE_TRANSLATE_URL=https://libretranslate.com/translate

# Путь к yt-dlp (по умолчанию ищет в PATH)
YTDLP_PATH=yt-dlp

# Путь к ffmpeg (по умолчанию ищет в PATH)
FFMPEG_PATH=ffmpeg

# Провайдеры по умолчанию
DEFAULT_STT_PROVIDER=whisper
DEFAULT_TRANSLATION_PROVIDER=libre
DEFAULT_TTS_PROVIDER=edge-tts
