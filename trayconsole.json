{
  "name": "YouTube Translator",
  "icon": null,
  "ownTrayIcon": false,
  "autostart": true,
  "openFolder": true,
  "components": [
    {
      "name": "Backend",
      "lifecycle": {
        "start": "pythonw trayconsole_bridge.py",
        "stop": null,
        "build": null
      },
      "pipe": "trayconsole_yttranslator_server",
      "window": false,
      "customActions": [
        { "label": "Открыть веб-интерфейс", "command": "open_ui" }
      ]
    },
    {
      "name": "CosyVoice TTS (WSL2)",
      "lifecycle": {
        "start": "pythonw trayconsole_cosyvoice_bridge.py",
        "stop": null,
        "build": null
      },
      "pipe": "trayconsole_cosyvoice",
      "window": false,
      "customActions": []
    }
  ]
}
