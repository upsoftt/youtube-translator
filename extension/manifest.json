{
  "manifest_version": 3,
  "name": "YouTube Translator",
  "version": "1.0.0",
  "description": "Синхронный перевод YouTube видео в реальном времени через локальный сервер",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:8211/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Translator"
  }
}
